# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Secret used to sign JWTs — any long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me

# Postgres connection string — get from Neon (dev) or Railway (prod)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Max Claude API calls per user per day (default: 50)
DAILY_CALL_LIMIT=50

# Production frontend origin for CORS (e.g. https://your-app.railway.app)
# ALLOWED_ORIGIN=https://your-app.railway.app
